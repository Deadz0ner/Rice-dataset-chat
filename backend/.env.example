APP_NAME=Rice Dataset Chat API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173
DATA_DIR=./data
DEFAULT_DATASET_PATH=
VECTOR_BACKEND=faiss
# Use "openai" for OpenAI, "groq" when pointing OPENAI_BASE_URL at Groq.
LLM_PROVIDER=openai
OPENAI_API_KEY=
# Leave blank for OpenAI. For Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=
# OpenAI example: gpt-4o-mini   |  Groq example: llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO
